# Copy to .env and fill in before: docker compose up -d
#
# Generate values:
#   DEPLOYBOT_KEY=$(head -c 32 /dev/urandom | base64)
#   DEPLOYBOT_SESSION_KEY=$(head -c 32 /dev/urandom | base64)
#   DEPLOYBOT_ADMIN_HASH=$(docker run --rm ghcr.io/tomusdrw/github-deploy-bot:latest hash-password 'your-password')

DEPLOYBOT_KEY=
DEPLOYBOT_SESSION_KEY=
DEPLOYBOT_ADMIN_HASH=
DEPLOYBOT_PORT=8080
DEPLOYBOT_POLL_INTERVAL=60s
